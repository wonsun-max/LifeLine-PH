rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    function isValidUserCreate(data, userId) {
      return data.keys().hasAll(['uid', 'email', 'createdAt', 'updatedAt'])
        && data.uid == userId
        && data.email is string && data.email.size() <= 256
        && data.createdAt == request.time
        && data.updatedAt == request.time
        && ( !('displayName' in data) || (data.displayName is string && data.displayName.size() <= 100) )
        && ( !('age' in data) || data.age is number )
        && ( !('gender' in data) || (data.gender is string && data.gender.size() <= 20) )
        && ( !('medicalConditions' in data) || (data.medicalConditions is list && data.medicalConditions.size() <= 50 && (data.medicalConditions.size() == 0 || data.medicalConditions[0] is string)) )
        && ( !('medications' in data) || (data.medications is list && data.medications.size() <= 50 && (data.medications.size() == 0 || data.medications[0] is string)) )
        && ( !('customCategories' in data) || (data.customCategories is list && data.customCategories.size() <= 20 && (data.customCategories.size() == 0 || data.customCategories[0] is string)) );
    }

    function isValidUserUpdate(data, existingData, userId) {
      return data.uid == userId
        && data.email is string && data.email.size() <= 256
        && data.createdAt == existingData.createdAt
        && data.updatedAt == request.time
        && ( !('displayName' in data) || (data.displayName is string && data.displayName.size() <= 100) )
        && ( !('age' in data) || data.age is number )
        && ( !('gender' in data) || (data.gender is string && data.gender.size() <= 20) )
        && ( !('medicalConditions' in data) || (data.medicalConditions is list && data.medicalConditions.size() <= 50 && (data.medicalConditions.size() == 0 || data.medicalConditions[0] is string)) )
        && ( !('medications' in data) || (data.medications is list && data.medications.size() <= 50 && (data.medications.size() == 0 || data.medications[0] is string)) )
        && ( !('customCategories' in data) || (data.customCategories is list && data.customCategories.size() <= 20 && (data.customCategories.size() == 0 || data.customCategories[0] is string)) );
    }

    match /users/{userId} {
      allow read: if isOwner(userId) && request.auth.token.email_verified == true;
      allow create: if isOwner(userId) && isValidId(userId) && isValidUserCreate(incoming(), userId) && request.auth.token.email_verified == true;
      allow update: if isOwner(userId) && isValidId(userId) && isValidUserUpdate(incoming(), existing(), userId) && request.auth.token.email_verified == true && (
        (incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'age', 'gender', 'medicalConditions', 'medications', 'customCategories', 'updatedAt']))
      );
    }
  }
}
